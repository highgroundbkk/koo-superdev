# KOO Superdev - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (for multi-model support via OpenRouter)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic API Key (for direct Claude/Sonnet access)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: OpenAI API Key (for GPT-4 access via OpenRouter)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Development mode for debugging
DEBUG=false

# Optional: Session storage directory (default: ~/.koo-sessions)
SESSION_DIR=~/.koo-sessions

# Optional: Configuration directory (default: ~/.koo-config)
CONFIG_DIR=~/.koo-config

# Optional: Community packs auto-install (comma-separated list)
# PACKS=debug,safe,fast,deep

# Optional: Default agent preset
# DEFAULT_AGENT=superpowers

# Optional: Enable verbose logging
VERBOSE=false
