{
  "name": "koo-superdev",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "koo": "./dist/koo.js",
    "koo-tui": "./dist/koo-tui.js",
    "koo-cli": "./dist/koo-cli.js"
  },
  "scripts": {
    "start": "npx ts-node --esm koo.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "bash scripts/test.sh",
    "setup": "bash scripts/setup.sh",
    "dev": "npm run watch",
    "cli": "node dist/koo-cli.js",
    "tui": "node dist/koo-tui.js",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "glob": "^13.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
