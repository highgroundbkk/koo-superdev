{
  "name": "koo-superdev",
  "version": "1.0.0",
  "description": "🚀 Premium Agentic AI CLI with community packs, agent profiles, and interactive slash commands",
  "author": "KOO Superdev Team",
  "license": "MIT",
  "homepage": "https://github.com/koo/koo-superdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/koo/koo-superdev.git"
  },
  "bugs": {
    "url": "https://github.com/koo/koo-superdev/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "assistant",
    "agentic",
    "superdev",
    "typescript",
    "openrouter",
    "anthropic"
  ],
  "type": "module",
  "bin": {
    "koo": "./dist/koo.js",
    "koo-tui": "./dist/koo-tui.js",
    "koo-cli": "./dist/koo-cli.js"
  },
  "scripts": {
    "start": "npx ts-node --esm koo.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "bash scripts/test.sh",
    "setup": "bash scripts/setup.sh",
    "dev": "npm run watch",
    "cli": "node dist/koo-cli.js",
    "tui": "node dist/koo-tui.js",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "glob": "^13.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
